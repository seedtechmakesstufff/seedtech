// ── SeedTech Database Schema ──
// PostgreSQL on Neon, managed via Prisma
// Multi-tenant: every SEO/content model is scoped to a Site

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Multi-Tenant Core ───────────────────────────────

model Tenant {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  memberships Membership[]
  sites       Site[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("tenants")
}

model User {
  id           String             @id @default(cuid())
  email        String             @unique
  passwordHash String
  name         String?
  memberships  Membership[]
  reportPrefs  ReportPreference[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@map("users")
}

enum MemberRole {
  owner
  admin
  editor
  viewer
}

model Membership {
  userId   String
  tenantId String
  role     MemberRole @default(editor)
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([userId, tenantId])
  @@map("memberships")
}

model Site {
  id                String                  @id @default(cuid())
  tenantId          String
  name              String
  slug              String
  domain            String
  siteUrl           String
  defaultOgImageUrl String?
  tenant            Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  businessProfile  BusinessProfile?
  industryConfig   IndustryConfig?
  pages            SitePage[]
  integrations     IntegrationCredential[]
  blogPosts        BlogPost[]
  seoSnapshots     SeoSnapshot[]
  seoCrawlRuns     SeoCrawlRun[]
  seoPageAudits    SeoPageAudit[]
  seoInsights      SeoInsight[]
  trackedKeywords  TrackedKeyword[]
  keywordClusters  KeywordCluster[]
  contentScores    ContentScore[]
  competitors      CompetitorDomain[]
  compAnalyses     CompetitorAnalysis[]
  leadEvents       SeoLeadEvent[]
  aiCitations      AICitation[]
  citationRuns     CitationCheckRun[]
  aiVisScores      AIVisibilityScore[]
  seoTasks         SeoTask[]
  contentIdeas     ContentIdea[]
  authors          Author[]
  evidence         ExperienceEvidence[]
  cronRuns         CronJobRun[]
  linkSuggestions  InternalLinkSuggestion[]
  pageMetadata     PageMetadata[]
  pageContexts     PageContext[]
  contextNodes     ContextNode[]
  gscSyncLogs      GscSyncLog[]
  gscDailyKeywords GscDailyKeyword[]
  gscDailyPages    GscDailyPage[]
  reportPrefs      ReportPreference[]
  strategyDocs     SeoStrategyDoc[]
  gbpLocations     GbpLocation[]
  pageMetrics      PageMetrics[]
  events           Event[]
  agentArtifacts   AgentArtifact[]
  researchSignals  ResearchSignal[]
  agentRuns        AgentRun[]
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@unique([tenantId, slug])
  @@map("sites")
}

model SitePage {
  id        String   @id @default(cuid())
  siteId    String
  path      String
  kind      String   // home, service, location, blog, landing
  title     String?
  source    String   @default("manual") // cms, blog, manual, discovered
  status    String   @default("active")
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([siteId, path])
  @@index([siteId, kind])
  @@map("site_pages")
}

model BusinessProfile {
  id                  String   @id @default(cuid())
  siteId              String   @unique
  companyName         String
  tagline             String   @default("")
  location            String   @default("")
  domain              String   @default("")
  primaryService      String   @default("")
  secondaryServices   String[] @default([])
  targetAudience      String   @default("")
  uniqueSellingPoints String[] @default([])
  toneOfVoice         String   @default("")
  customInstructions  String   @default("") @db.Text
  logoUrl             String?  // Uploaded company logo, served from /uploads/logos/
  serviceCategories   Json?    // [{name, slug, moneyPage}]
  brandEntities       String[] @default([])
  ctaDefaults         Json?    // {primaryCta, secondaryCta}
  internalLinkTargets Json?    // [{path, label, keywords}]
  site                Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("business_profiles")
}

enum IntegrationType {
  google_search_console
  google_analytics          // GA4 — used by PageMetrics ingestion
  google_pagespeed
  google_business_profile   // GBP — locations, posts, reviews, performance
  wordpress                 // WordPress REST API (Application Password auth)
}

// ── Email Template Overrides ────────────────────────────────

enum EmailTemplateKey {
  contact_notification    // Internal alert when contact form is submitted
  contact_auto_reply      // Auto-reply to the person who submitted the contact form
  quote_notification      // Internal alert when a quote flow is completed
  quote_auto_reply        // Auto-reply to the person who submitted a quote
  team_invite             // Invite email sent to new team members
}

model EmailTemplateOverride {
  id        String           @id @default(cuid())
  siteId    String
  key       EmailTemplateKey
  subject   String           // Editable subject line
  heading   String           // Editable main heading (h1)
  body      String           @db.Text // Editable body copy (plain text, rendered into the HTML layout)
  enabled   Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([siteId, key])
  @@map("email_template_overrides")
}

// ── Email Config (DB-stored sender + recipient settings) ────

model EmailConfig {
  id               String   @id @default(cuid())
  siteId           String   @unique
  fromAddress      String   @default("")
  notifyRecipients String   @default("") // comma-separated admin emails
  reportFromEmail  String   @default("")
  reportToEmail    String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("email_configs")
}

model IntegrationCredential {
  id                  String          @id @default(cuid())
  siteId              String
  type                IntegrationType
  property            String          @default("")  // e.g. GSC property URL
  authType            String          @default("service-account") // service-account | oauth
  encryptedCredentials String?        @db.Text
  isActive            Boolean         @default(true)
  site                Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@unique([siteId, type])
  @@map("integration_credentials")
}

// ── Blog Posts ──────────────────────────────────────

enum PostStatus {
  draft
  published
  scheduled
}

model BlogPost {
  id              String     @id @default(uuid())
  siteId          String
  title           String
  slug            String
  excerpt         String
  body            String     // Markdown content
  author          String     @default("")
  authorId        String?                            // FK to Author (optional for backwards compat)
  authorRef       Author?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  category        String
  tags            String[]   @default([])
  targetKeyword   String     @default("")
  metaTitle       String     @default("")
  metaDescription String     @default("")
  structuredData  Json?                              // JSON-LD (Article, FAQPage, etc.)
  status          PostStatus @default(draft)
  wordCount       Int        @default(0)
  publishedAt     DateTime?
  scheduledAt     DateTime?
  wordPressPostId Int?                               // Set on WordPress sync; null for SeedTech-native posts
  wordPressSiteUrl String?                           // Source WP site URL (e.g. "https://client.com")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  site            Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, slug])
  @@index([siteId, status])
  @@index([createdAt])
  @@index([authorId])
  @@map("blog_posts")
}

// ── Contacts ────────────────────────────────────────

model Contact {
  id          String    @id @default(uuid())
  siteId      String
  fullName    String
  email       String
  phone       String?
  company     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  submissions FormSubmission[]

  @@index([siteId, email])
  @@map("contacts")
}

// ── Form Submissions ────────────────────────────────

enum FormSource {
  contact_page        // /contact page form
  quote_it            // IT Support quote flow
  quote_web           // Web Dev quote flow
}

enum SubmissionStatus {
  new
  read
  replied
  archived
}

model FormSubmission {
  id           String           @id @default(uuid())
  siteId       String
  source       FormSource
  status       SubmissionStatus @default(new)

  // Contact info (denormalized for quick access)
  fullName     String
  email        String
  phone        String?
  company      String?

  // Submission details
  service      String?   // "Managed IT Support", "Web Development", etc.
  message      String?   // Free-text message from contact page
  tier         String?   // "Starter", "Growth", etc. for quote flows
  metadata     Json?     // Any extra structured data (quote config, etc.)

  // Relations
  contactId    String?
  contact      Contact?  @relation(fields: [contactId], references: [id])

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([siteId, status])
  @@index([source])
  @@index([createdAt])
  @@map("form_submissions")
}

// ── SEO Snapshots (weekly keyword/traffic history) ──

model SeoSnapshot {
  id              String   @id @default(uuid())
  siteId          String
  date            DateTime @default(now())     // snapshot date
  totalClicks     Int      @default(0)
  totalImpressions Int     @default(0)
  avgCtr          Float    @default(0)
  avgPosition     Float    @default(0)
  healthScore     Int      @default(0)         // 0-100 aggregate
  performanceScore Int     @default(0)         // PageSpeed perf avg
  seoScore        Int      @default(0)         // PageSpeed SEO avg
  keywordPositions Json    @default("{}")      // { "keyword": position }
  topPages        Json     @default("[]")      // [{ page, clicks, impressions }]
  metadata        Json?                        // any extra data
  site            Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())

  @@index([siteId, date])
  @@map("seo_snapshots")
}

// ── SEO Page Audit Results ──

enum AuditSeverity {
  critical
  warning
  info
  pass
}

model SeoPageAudit {
  id          String        @id @default(uuid())
  siteId      String
  runId       String                             // groups issues from the same crawl
  url         String
  checkType   String                             // "missing-title", "thin-content", etc.
  severity    AuditSeverity
  message     String
  details     Json?                              // extra context
  site        Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())

  @@index([siteId, runId])
  @@index([createdAt])
  @@map("seo_page_audits")
}

// ── SEO Crawl Runs (metadata per crawl execution) ──

model SeoCrawlRun {
  id              String    @id @default(uuid())
  siteId          String
  runId           String    @unique               // matches SeoPageAudit.runId
  status          String    @default("running")   // running, completed, failed
  pagesScanned    Int       @default(0)
  criticalCount   Int       @default(0)
  warningCount    Int       @default(0)
  infoCount       Int       @default(0)
  passCount       Int       @default(0)
  eeatScore       Int?                            // aggregate E-E-A-T score
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  errorMessage    String?
  site            Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())

  @@index([siteId, createdAt])
  @@map("seo_crawl_runs")
}

// ── SEO Insights (freshness, cannibalization, linking) ──

enum InsightType {
  content_freshness
  cannibalization
  internal_linking
  keyword_opportunity
  eeat_issue
  aio_opportunity
  ctr_optimization
  competitor_gap
  lead_gen
  general
}

enum InsightStatus {
  active
  dismissed
  resolved
}

model SeoInsight {
  id          String        @id @default(uuid())
  siteId      String
  type        InsightType
  status      InsightStatus @default(active)
  title       String
  description String
  actionUrl   String?                            // page to fix
  priority    Int           @default(50)         // 0-100, higher = more urgent
  metadata    Json?
  site        Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  resolvedAt  DateTime?

  @@index([siteId, type])
  @@index([siteId, status])
  @@index([createdAt])
  @@map("seo_insights")
}

// ── Tracked Keywords (DB-driven, replaces static file) ──

enum KeywordTier {
  tier1
  tier2
  tier3
}

enum KeywordIntent {
  transactional
  commercial
  informational
  navigational
}

model TrackedKeyword {
  id              String        @id @default(uuid())
  siteId          String
  keyword         String
  tier            KeywordTier   @default(tier2)
  volume          String        @default("unknown")
  competition     String        @default("medium")
  intent          KeywordIntent @default(informational)
  targetPage      String        @default("/")
  currentPosition Float?                               // latest GSC position
  previousPosition Float?                              // previous week position
  bestPosition    Float?                               // all-time best
  clicks28d       Int           @default(0)            // last 28 days
  impressions28d  Int           @default(0)
  ctr28d          Float         @default(0)
  clusterId       String?
  cluster         KeywordCluster? @relation(fields: [clusterId], references: [id])
  isActive        Boolean       @default(true)
  site            Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([siteId, keyword])
  @@index([siteId, tier])
  @@index([siteId, isActive])
  @@index([clusterId])
  @@map("tracked_keywords")
}

model KeywordCluster {
  id              String           @id @default(uuid())
  siteId          String
  name            String
  pillarPage      String                               // the main page for this topic cluster
  description     String?
  seedKeyword     String           @default("")        // the keyword used to generate this cluster
  status          String           @default("draft")   // draft, active, archived
  // Authority scoring
  authorityScore  Int?                                 // 0-100 composite authority
  coveragePercent Float?                               // % of subtopics with published content
  avgContentScore Float?                               // avg E-E-A-T + AIO across cluster content
  avgAiVisScore   Float?                               // avg AI Visibility score
  linkDensity     Float?                               // internal links per page within cluster
  lastScoredAt    DateTime?
  // Relations
  keywords        TrackedKeyword[]
  subtopics       ClusterSubtopic[]
  linkSuggestions InternalLinkSuggestion[]
  contentIdeas    ContentIdea[]
  site            Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([siteId, name])
  @@map("keyword_clusters")
}

// ── Cluster Subtopics (spoke pages in a topic cluster) ──
// Each subtopic represents a spoke page that supports the pillar.
model ClusterSubtopic {
  id              String          @id @default(uuid())
  clusterId       String
  title           String                               // subtopic title / H1
  slug            String                               // suggested URL slug
  targetKeyword   String                               // primary keyword for this spoke
  searchIntent    String          @default("informational") // transactional, commercial, informational, navigational
  contentStatus   String          @default("missing")  // missing, idea, draft, published
  matchedPageUrl  String?                              // existing page URL if content exists
  matchedBlogId   String?                              // matched BlogPost.id if applicable
  priority        Int             @default(50)         // 0-100, higher = create first
  wordCountTarget Int             @default(1500)
  briefNotes      String?         @db.Text             // AI-generated content brief
  cluster         KeywordCluster  @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([clusterId, slug])
  @@index([clusterId, contentStatus])
  @@map("cluster_subtopics")
}

// ── Internal Link Suggestions ──
// AI-generated suggestions to add internal links within and across clusters.
model InternalLinkSuggestion {
  id              String          @id @default(uuid())
  siteId          String
  clusterId       String?
  sourcePageUrl   String                               // page that should add a link
  targetPageUrl   String                               // page to link TO
  anchorText      String                               // suggested anchor text
  context         String?         @db.Text             // surrounding sentence or paragraph
  reason          String                               // why this link should exist
  status          String          @default("pending")  // pending, accepted, dismissed
  cluster         KeywordCluster? @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  site            Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdAt       DateTime        @default(now())

  @@unique([siteId, sourcePageUrl, targetPageUrl])
  @@index([siteId, status])
  @@index([clusterId])
  @@map("internal_link_suggestions")
}

// ── Content Scoring ──

model ContentScore {
  id             String   @id @default(uuid())
  siteId         String
  pageUrl        String                                // page path (e.g. /blog/my-post)
  blogPostId     String?                               // optional link to BlogPost
  eeatScore      Int      @default(0)                  // 0-100
  aioScore       Int      @default(0)                  // 0-100
  overallScore   Int      @default(0)                  // 0-100
  wordCount      Int      @default(0)
  readabilityGrade Float  @default(0)                  // Flesch-Kincaid grade level
  internalLinks  Int      @default(0)
  externalLinks  Int      @default(0)
  hasSchema      Boolean  @default(false)
  hasFaq         Boolean  @default(false)
  hasSpeakable   Boolean  @default(false)
  issues         Json     @default("[]")               // [{type, message, severity}]
  site           Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  scoredAt       DateTime @default(now())

  @@unique([siteId, pageUrl])
  @@index([siteId, overallScore])
  @@index([scoredAt])
  @@map("content_scores")
}

// ── Competitor Intelligence ──

model CompetitorDomain {
  id              String   @id @default(uuid())
  siteId          String
  domain          String                               // e.g. "competitor.com"
  name            String                               // friendly name
  overlapKeywords Int      @default(0)                 // # of shared keywords
  avgPosition     Float?                               // their avg position on shared keywords
  notes           String?
  isActive        Boolean  @default(true)
  lastAnalyzed    DateTime?
  metadata        Json?                                // extra data from analysis
  site            Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  compAnalyses    CompetitorAnalysis[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([siteId, domain])
  @@index([siteId, isActive])
  @@map("competitor_domains")
}

// ── Lead Tracking (SEO → Conversion) ──

model SeoLeadEvent {
  id           String   @id @default(uuid())
  siteId       String
  sessionId    String?                                 // anonymous session tracking
  landingPage  String                                  // first page they hit
  conversionPage String?                               // page where they converted (contact, quote)
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  referrer     String?
  keyword      String?                                 // if we can detect the keyword
  eventType    String                                  // "page_view", "cta_click", "form_submit"
  metadata     Json?
  site         Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@index([siteId, eventType])
  @@index([siteId, landingPage])
  @@index([createdAt])
  @@map("seo_lead_events")
}

// ── AI Citation Tracking ──
// Tracks brand mentions in AI-generated responses.
// Used to measure AI Visibility over time.
model AICitation {
  id             String   @id @default(uuid())
  siteId         String
  checkRunId     String?                               // links to CitationCheckRun batch
  platform       String                                // "chatgpt", "perplexity", "gemini", "google_aio", "copilot"
  query          String                                // the query that triggered the AI response
  brandMentioned Boolean  @default(false)              // was our brand mentioned?
  urlCited       String?                               // was a specific URL cited?
  context        String?  @db.Text                     // snippet of the AI response mentioning us
  citationType   String?                               // "direct_quote", "brand_mention", "url_citation", "recommendation"
  sentiment      String?                               // "positive", "neutral", "negative"
  competitorId   String?                               // if tracking a competitor mention
  responseLength Int?                                  // total response length in chars
  position       Int?                                  // position of brand mention in response (1 = first mention)
  metadata       Json?
  checkRun       CitationCheckRun? @relation(fields: [checkRunId], references: [id], onDelete: SetNull)
  site           Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  checkedAt      DateTime @default(now())

  @@index([siteId, platform])
  @@index([siteId, brandMentioned])
  @@index([siteId, checkRunId])
  @@index([checkedAt])
  @@map("ai_citations")
}

// ── Citation Check Runs (batch execution tracking) ──
// Each run queries multiple platforms with multiple queries and records all results.
model CitationCheckRun {
  id             String      @id @default(uuid())
  siteId         String
  status         String      @default("running")       // running, completed, failed
  totalQueries   Int         @default(0)
  totalPlatforms Int         @default(0)
  brandMentions  Int         @default(0)               // total brand mentions found
  urlCitations   Int         @default(0)               // total URL citations found
  mentionRate    Float?                                // brandMentions / totalChecks
  startedAt      DateTime    @default(now())
  completedAt    DateTime?
  durationMs     Int?
  errorMessage   String?
  citations      AICitation[]
  site           Site        @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdAt      DateTime    @default(now())

  @@index([siteId, createdAt])
  @@map("citation_check_runs")
}

// ── AI Visibility Scores (historical tracking) ──
// Stores periodic AI Visibility scores per page for trend tracking.
model AIVisibilityScore {
  id              String   @id @default(uuid())
  siteId          String
  pageUrl         String
  overallScore    Int
  citationReadiness Int
  entityAuthority Int
  structuredClarity Int
  conversationalFit Int
  multiEngineCoverage Int
  grade           String                               // "A", "B", "C", "D", "F"
  failedChecks    Json?                                // array of failed check names
  site            Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  scoredAt        DateTime @default(now())

  @@index([siteId, pageUrl])
  @@index([scoredAt])
  @@map("ai_visibility_scores")
}

// ── SEO Tasks (implementation roadmap) ──
// Replaces the static SEO_TASKS array from seo-strategy.ts.
model SeoTask {
  id        String   @id @default(cuid())
  siteId    String
  phase     Int      @default(1)
  title     String
  status    String   @default("not-started") // "done", "in-progress", "not-started"
  priority  String   @default("medium")      // "critical", "high", "medium", "low"
  // Source tracking for crawl-generated tasks (dedup + auto-resolve)
  sourceType     String?                     // "crawl", "insight", "manual"
  sourceUrl      String?                     // page URL the issue was found on
  sourceCheckType String?                    // crawl checkType (e.g. "missing-title")
  sourceRunId    String?                     // crawl runId that generated this task
  autoResolved   Boolean  @default(false)    // true if auto-closed when issue disappeared
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([siteId, status])
  @@index([siteId, sourceUrl, sourceCheckType])
  @@map("seo_tasks")
}

// ── Content Ideas / Calendar ──
// Replaces the static CONTENT_CALENDAR array from seo-strategy.ts.
model ContentIdea {
  id            String          @id @default(cuid())
  siteId        String
  title         String
  targetKeyword String
  wordCount     Int             @default(1500)
  funnelStage   String          @default("Top")
  status        String          @default("idea") // "published", "draft", "scheduled", "idea"
  slug          String?
  clusterId     String?
  cluster       KeywordCluster? @relation(fields: [clusterId], references: [id], onDelete: SetNull)
  site          Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([siteId, status])
  @@index([clusterId])
  @@map("content_ideas")
}

// ── Authors (per-site expert entities for E-E-A-T) ──

model Author {
  id           String     @id @default(cuid())
  siteId       String
  name         String
  slug         String
  jobTitle     String     @default("")
  bio          String     @default("") @db.Text
  imageUrl     String?
  canonicalUrl String     @default("")  // /about#sam or /team/sam
  sameAs       String[]   @default([])  // LinkedIn, GitHub, etc.
  expertise    String[]   @default([])  // topics qualified to write about
  credentials  String[]   @default([])  // CompTIA A+, CISSP, etc.
  experience   String     @default("")  // "15+ years in cybersecurity"
  isDefault    Boolean    @default(false)
  site         Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  blogPosts    BlogPost[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([siteId, slug])
  @@index([siteId, isDefault])
  @@map("authors")
}

// ── Experience Evidence (real data to inject into AI content) ──
// Case studies, metrics, testimonials, certifications — the REAL E-E-A-T signals.

model ExperienceEvidence {
  id        String   @id @default(cuid())
  siteId    String
  type      String   // "case_study", "metric", "testimonial", "certification", "process"
  title     String
  content   String   @db.Text  // The quotable evidence
  source    String?  // Client name, cert body, etc.
  tags      String[] @default([])  // Topics this applies to
  isPublic  Boolean  @default(true)
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([siteId, type])
  @@map("experience_evidence")
}

// ── Industry Config (per-site scoring customization) ──
// Replaces hardcoded credential/geography/entity lists.

model IndustryConfig {
  id                  String   @id @default(cuid())
  siteId              String   @unique
  industry            String   @default("general") // msp, legal, hvac, saas, etc.
  credentialKeywords  String[] @default([])  // ["CompTIA", "CISSP", "Bar Association"]
  geographicTerms     String[] @default([])  // ["Northern NJ", "Bergen County"]
  knownEntities       String[] @default([])  // ["Microsoft", "NIST", "OSHA"]
  authorityDomains    String[] @default([])  // ["nist.gov", "cisa.gov"]
  site                Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("industry_configs")
}

// ── Competitor Analysis (results of analyzing competitor pages) ──

model CompetitorAnalysis {
  id               String   @id @default(cuid())
  siteId           String
  competitorId     String
  competitor       CompetitorDomain @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  pageUrl          String            // competitor page URL crawled
  pageTitle        String?
  wordCount        Int      @default(0)
  aiVisScore       Int      @default(0)
  eeatScore        Int      @default(0)
  topicsDetected   String[] @default([]) // topics covered on this page
  hasSchema        Boolean  @default(false)
  hasFaq           Boolean  @default(false)
  metadata         Json?
  site             Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  analyzedAt       DateTime @default(now())

  @@index([siteId, competitorId])
  @@index([analyzedAt])
  @@map("competitor_analyses")
}

// ── Cron Job Run Tracking ──
// Tracks execution of scheduled jobs (snapshots, crawls, reports).

model CronJobRun {
  id           String    @id @default(cuid())
  siteId       String
  jobType      String    // "snapshot", "crawl", "gsc_pull", "report", "insights"
  status       String    @default("running") // "running", "completed", "failed"
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  durationMs   Int?
  resultSummary String?
  errorMessage String?
  site         Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())

  @@index([siteId, jobType])
  @@index([startedAt])
  @@map("cron_job_runs")
}

// ── AgentRun ───────────────────────────────────────────────────────────────
// One row per agent invocation (cron or manual). Observability layer:
// answers "which agent is expensive, noisy, or actually useful?"
// inputSnapshotHash lets you dedupe identical inputs across runs.

enum AgentRunStatus {
  running
  completed
  failed
}

enum AgentRunTrigger {
  cron
  manual
  run_all
  chained
}

model AgentRun {
  id                 String          @id @default(cuid())
  siteId             String
  agentKey           String          // "industry-researcher", "blog-drafter", ...
  trigger            AgentRunTrigger @default(cron)
  status             AgentRunStatus  @default(running)
  startedAt          DateTime        @default(now())
  completedAt        DateTime?
  durationMs         Int?
  // Input fingerprint — sha256 of the inputs the agent read. Optional.
  inputSnapshotHash  String?
  // LLM accounting
  model              String?         // e.g. "claude-sonnet-4-20250514"
  tokensIn           Int?
  tokensOut          Int?
  costEstimateUsd    Decimal?        @db.Decimal(10, 6)
  // Output accounting
  artifactsCreated   Int             @default(0)
  artifactIds        String[]        @default([])
  resultSummary      String?         // short human-readable summary
  error              String?         @db.Text
  // Free-form structured metadata (counts, flags, source agent for chained runs)
  metadata           Json?
  site               Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdAt          DateTime        @default(now())

  @@index([siteId, agentKey])
  @@index([siteId, startedAt])
  @@index([startedAt])
  @@index([agentKey, status])
  @@map("agent_runs")
}

// ── User Invites ──
// Pending team member invitations.

model UserInvite {
  id        String   @id @default(cuid())
  tenantId  String
  email     String
  role      MemberRole @default(editor)
  invitedBy String   // userId of inviter
  token     String   @unique @default(cuid()) // unique invite link token
  expiresAt DateTime
  acceptedAt DateTime?
  createdAt DateTime @default(now())

  @@index([tenantId, email])
  @@index([token])
  @@map("user_invites")
}

// ── Page Metadata Management (SEO Autopilot — Metadata Tab) ──

model PageMetadata {
  id              String   @id @default(cuid())
  siteId          String
  path            String                          // e.g. "/about", "/services/managed-it"
  title           String?                         // <title> tag
  description     String?                         // <meta name="description">
  ogTitle         String?                         // og:title override (falls back to title)
  ogDescription   String?                         // og:description override (falls back to description)
  ogImageUrl      String?                         // og:image URL
  twitterCard     String   @default("summary_large_image")
  canonical       String?                         // <link rel="canonical">
  noIndex         Boolean  @default(false)        // robots noindex
  noFollow        Boolean  @default(false)        // robots nofollow
  jsonLdType      String?                         // "Service", "Article", "LocalBusiness", etc.
  jsonLdData      Json?                           // full JSON-LD payload
  lastCrawledAt   DateTime?                       // last time crawler verified this page
  crawlStatus     String?                         // "complete", "missing-og", "missing-desc", etc.
  lastEditedBy    String?                         // userId who last edited
  site            Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([siteId, path])
  @@index([siteId])
  @@map("page_metadata")
}

// ── Page Context (AI-facing descriptions for each page) ──
// These are human-written descriptions of what each page covers,
// used as the PRIMARY signal when AI generates metadata, blog intros, etc.
model PageContext {
  id          String   @id @default(cuid())
  siteId      String
  path        String                          // e.g. "/services/seedtech-platform"
  description String   @db.Text              // 2-4 sentence description of what this page covers
  keywords    String[] @default([])           // keywords specifically relevant to this page
  pageType    String   @default("page")       // page, service, industry, blog, landing
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  linkedNodes PageContextNode[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([siteId, path])
  @@index([siteId])
  @@map("page_contexts")
}

// ── Context Nodes (service/offering/product context for AI) ──
// Each node represents a distinct service, product, or offering with rich structured context.
// Linked to pages via PageContextNode junction with relevance levels.
model ContextNode {
  id              String            @id @default(cuid())
  siteId          String
  name            String                            // "Managed IT Support", "Cloud Migration"
  slug            String                            // auto-generated from name, used for fallback matching
  nodeType        String            @default("service") // service, offering, division, product
  color           String            @default("#a855f7")  // hex color for UI cards
  icon            String            @default("Briefcase") // lucide icon name

  // ── Structured context fields ──
  summary         String            @db.Text         // 2-3 sentence elevator pitch
  audience        String?           @db.Text         // who this is for
  pricing         String?           @db.Text         // pricing model / range
  usps            String[]          @default([])     // unique selling points
  messaging       String?           @db.Text         // key messaging guidelines
  doSay           String[]          @default([])     // phrases/terms to use
  dontSay         String[]          @default([])     // phrases/terms to avoid
  competitors     String[]          @default([])     // competitor names for differentiation
  detailedContext String?           @db.Text         // freeform rich context (markdown)

  // ── Canvas position (persisted for visual layout) ──
  posX            Float             @default(0)
  posY            Float             @default(0)

  site            Site              @relation(fields: [siteId], references: [id], onDelete: Cascade)
  linkedPages     PageContextNode[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([siteId, slug])
  @@index([siteId])
  @@map("context_nodes")
}

// ── Junction: which context nodes are relevant to which pages ──
model PageContextNode {
  id              String       @id @default(cuid())
  pageContextId   String
  contextNodeId   String
  relevance       String       @default("primary")  // primary (full context), secondary (summary only), mention (name only)

  pageContext     PageContext   @relation(fields: [pageContextId], references: [id], onDelete: Cascade)
  contextNode     ContextNode  @relation(fields: [contextNodeId], references: [id], onDelete: Cascade)
  createdAt       DateTime     @default(now())

  @@unique([pageContextId, contextNodeId])
  @@index([pageContextId])
  @@index([contextNodeId])
  @@map("page_context_nodes")
}

// ── GSC Sync Logs (tracks each sync execution) ──
// One row per sync run — shows when data was last pulled and what was fetched.

model GscSyncLog {
  id              String    @id @default(cuid())
  siteId          String
  status          String    @default("running") // running, completed, failed
  syncType        String    @default("full")    // full, keywords-only, pages-only
  keywordsFetched Int       @default(0)
  pagesFetched    Int       @default(0)
  keywordsUpdated Int       @default(0)         // TrackedKeyword records updated
  daysRange       Int       @default(28)        // how many days of data pulled
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  durationMs      Int?
  errorMessage    String?
  site            Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())

  @@index([siteId, createdAt])
  @@index([siteId, status])
  @@map("gsc_sync_logs")
}

// ── GSC Daily Keyword Data ──
// Historical keyword performance from GSC. One row per keyword per date.
// Enables trend charts and position tracking over time.

model GscDailyKeyword {
  id          String   @id @default(cuid())
  siteId      String
  date        DateTime @db.Date              // the day this data is for
  query       String                         // the search query / keyword
  clicks      Int      @default(0)
  impressions Int      @default(0)
  ctr         Float    @default(0)
  position    Float    @default(0)           // avg position for this day
  device      String   @default("all")       // all, mobile, desktop, tablet
  country     String   @default("all")       // all, or ISO 3166-1 alpha-3
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([siteId, date, query, device, country])
  @@index([siteId, query, date])
  @@index([siteId, date])
  @@map("gsc_daily_keywords")
}

// ── GSC Daily Page Data ──
// Historical page performance from GSC. One row per page per date.
// Enables per-page trend charts.

model GscDailyPage {
  id          String   @id @default(cuid())
  siteId      String
  date        DateTime @db.Date
  pageUrl     String                         // full URL from GSC
  clicks      Int      @default(0)
  impressions Int      @default(0)
  ctr         Float    @default(0)
  position    Float    @default(0)
  device      String   @default("all")
  country     String   @default("all")
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([siteId, date, pageUrl, device, country])
  @@index([siteId, pageUrl, date])
  @@index([siteId, date])
  @@map("gsc_daily_pages")
}

// ── Report Preferences (per-user SEO report delivery settings) ──
// Controls when and how often each user receives emailed SEO reports.

enum ReportFrequency {
  weekly
  monthly
}

model ReportPreference {
  id        String          @id @default(cuid())
  siteId    String
  userId    String
  email     String                              // deliver to this address
  frequency ReportFrequency @default(monthly)
  dayOfWeek Int             @default(1)         // 0=Sun..6=Sat (for weekly)
  dayOfMonth Int            @default(1)         // 1-28 (for monthly)
  hourOfDay  Int            @default(8)         // 0-23 UTC hour to send
  enabled   Boolean         @default(true)
  lastSentAt DateTime?
  site      Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([siteId, userId])
  @@index([frequency, enabled])
  @@map("report_preferences")
}

// ── SEO Strategy Documents ──
// Persistent, versioned strategy context that feeds into ALL AI prompts.
// Stores keyword rationale, audit findings, content roadmaps, etc.
// Active docs are injected into seo-context.ts alongside business profile,
// keywords, and page contexts so every AI feature has strategic awareness.

enum StrategyDocCategory {
  keyword_strategy    // Keyword thesis, tier logic, reactive keyword rationale
  content_roadmap     // Blog plan, content calendar reasoning, topic clusters
  audit_findings      // GSC analysis, AI research audit results, competitive intel
  competitive_analysis // Competitor landscape, differentiation strategy
  general             // Catch-all for strategy notes that don't fit above
}

model SeoStrategyDoc {
  id          String              @id @default(cuid())
  siteId      String
  title       String                                  // "Reactive Keyword Strategy" or "Q1 2026 Audit Findings"
  category    StrategyDocCategory @default(general)
  content     String              @db.Text             // Markdown — the strategy narrative
  isActive    Boolean             @default(true)       // Only active docs feed into AI prompts
  version     Int                 @default(1)          // Bumped on major rewrites
  source      String?                                  // "manual", "ai-audit", "gsc-sync" — how this doc was created
  site        Site                @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([siteId, isActive])
  @@index([siteId, category])
  @@map("seo_strategy_docs")
}

// ── Google Business Profile (GBP) ───────────────────────────
// Per-site locations, posts, reviews, and daily performance metrics.
// Populated by GBP sync agent (read) and GBP publishing agent (write).

model GbpLocation {
  id                String   @id @default(cuid())
  siteId            String
  accountId         String                  // Google account/business resource ("accounts/12345")
  locationId        String                  // Google location resource ("locations/67890")
  title             String
  primaryCategory   String?
  storefrontAddress String?  @db.Text       // JSON
  primaryPhone      String?
  websiteUri        String?
  serviceArea       String?  @db.Text       // JSON array
  labels            String?  @db.Text       // JSON array
  metadata          String?  @db.Text       // JSON full snapshot for fields we don't model individually
  isPrimary         Boolean  @default(false)
  lastSyncedAt      DateTime?

  site    Site               @relation(fields: [siteId], references: [id], onDelete: Cascade)
  posts   GbpPost[]
  reviews GbpReview[]
  metrics GbpMetricsDaily[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([siteId, locationId])
  @@index([siteId, isPrimary])
  @@map("gbp_locations")
}

model GbpPost {
  id           String    @id @default(cuid())
  locationId   String
  postName     String?                 // Google's resource name once published
  topicType    String                  // STANDARD | EVENT | OFFER | ALERT
  summary      String    @db.Text
  ctaType      String?                 // LEARN_MORE | CALL | ORDER | BOOK | SHOP | SIGN_UP
  ctaUrl       String?
  mediaUrl     String?                 // Image URL (uploaded to GBP or external)
  viewCount    Int?                    // Per-post impressions from GBP Post Insights
  clickCount   Int?                    // Per-post CTA clicks from GBP Post Insights
  state        String    @default("draft") // draft | pending_review | published | rejected | failed
  publishedAt  DateTime?
  searchUrl    String?                 // Public URL of the published post
  errorMessage String?   @db.Text
  metadata     String?   @db.Text      // JSON (offer dates, event start/end, etc.)

  location GbpLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId, state])
  @@index([locationId, publishedAt])
  @@map("gbp_posts")
}

model GbpReview {
  id           String    @id @default(cuid())
  locationId   String
  reviewName   String                  // Google's resource name (unique per review)
  reviewerName String?
  rating       Int                     // 1-5 (Google returns STAR_RATING enum; we store the int)
  comment      String?   @db.Text
  reply        String?   @db.Text
  replyAt      DateTime?
  createTime   DateTime
  updateTime   DateTime

  location GbpLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([locationId, reviewName])
  @@index([locationId, createTime])
  @@index([locationId, rating])
  @@map("gbp_reviews")
}

model GbpMetricsDaily {
  id         String   @id @default(cuid())
  locationId String
  date       DateTime @db.Date

  // GBP Performance API metric names — kept verbose so they map 1:1 to the API
  businessImpressionsDesktopMaps   Int @default(0)
  businessImpressionsDesktopSearch Int @default(0)
  businessImpressionsMobileMaps    Int @default(0)
  businessImpressionsMobileSearch  Int @default(0)
  callClicks                       Int @default(0)
  websiteClicks                    Int @default(0)
  drivingDirections                Int @default(0)
  businessBookings                 Int @default(0)
  businessConversations            Int @default(0)
  businessFoodOrders               Int @default(0)
  businessFoodMenuClicks           Int @default(0)

  location GbpLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([locationId, date])
  @@index([locationId, date])
  @@map("gbp_metrics_daily")
}

// ── GA4 Page Metrics ────────────────────────────────────────
// Daily per-URL behavior + conversion data. Source = "ga4" today;
// "manual" reserved for backfill / non-GA tracking later.

model PageMetrics {
  id                    String   @id @default(cuid())
  siteId                String
  url                   String                          // Full URL or path; pick one and stay consistent
  date                  DateTime @db.Date
  sessions              Int      @default(0)
  users                 Int      @default(0)
  engagedSessions       Int      @default(0)
  engagementRate        Float    @default(0)
  averageEngagementTime Float    @default(0)            // seconds
  bounceRate            Float    @default(0)
  conversions           Int      @default(0)
  revenue               Float    @default(0)
  source                String   @default("ga4")        // ga4 | manual

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([siteId, url, date, source])
  @@index([siteId, date])
  @@index([siteId, url])
  @@map("page_metrics")
}

// ── Event Log ───────────────────────────────────────────────
// Append-only feed of meaningful changes per site. Read by agents to know
// "what's different since last run." Examples: content.published,
// keyword.moved, metrics.conversion_drop, citation.lost, gbp.review_received.

model Event {
  id         String   @id @default(cuid())
  siteId     String
  type       String                       // dotted hierarchy (see EVENT_TYPES in src/lib/events.ts)
  severity   String   @default("info")    // info | warn | critical
  title      String                       // human-readable summary
  body       String?  @db.Text
  payload    Json?                        // structured data agents can read
  entityType String?                      // "BlogPost", "TrackedKeyword", "AICitation", etc.
  entityId   String?                      // FK by convention; entityType disambiguates
  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, occurredAt])
  @@index([siteId, type, occurredAt])
  @@index([siteId, severity, occurredAt])
  @@index([entityType, entityId])
  @@map("events")
}

// ── Agent Artifacts ─────────────────────────────────────────
// Items produced by agents that need human review before they take effect
// (publishing a GBP post, replying to a review, queueing a brief). Strategy
// briefs and analyses go into SeoStrategyDoc instead — those are advisory.

model AgentArtifact {
  id           String    @id @default(cuid())
  siteId       String
  agent        String                          // "gbp-review-reply", "gbp-post-drafter", "blog-drafter", "brief-generator"
  type         String                          // "review_reply_draft" | "gbp_post_draft" | "content_brief" | "blog_draft"
  state        String    @default("pending_review") // pending_review | approved | rejected | published | failed
  title        String
  summary      String?   @db.Text
  payload      Json                            // structured artifact (draft text, target IDs, suggested CTAs, etc.)
  entityType   String?                         // "GbpReview", "BlogPost", etc.
  entityId     String?
  reviewedBy   String?                         // user email/id
  reviewedAt   DateTime?
  reviewNotes  String?   @db.Text
  publishedAt  DateTime?
  publishError String?   @db.Text

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([siteId, state])
  @@index([siteId, agent])
  @@index([siteId, type])
  @@index([entityType, entityId])
  @@map("agent_artifacts")
}

// ── Research Signals (Industry Researcher Agent) ─────────────────────────────
// Each row is a novel insight fetched from a primary/credible external source.
// Signals feed into the Brief Generator so content is grounded in real-world
// events rather than recycled keyword ideas.

enum ResearchSignalStatus {
  fresh      // Not yet consumed by any brief
  consumed   // A content brief has been created from this signal
  dismissed  // Manually dismissed (low quality / not relevant)
}

model ResearchSignal {
  id            String              @id @default(cuid())
  siteId        String
  // Source metadata
  sourceUrl     String              // Canonical URL of the original article/rule/document
  sourceDomain  String              // e.g. "fmcsa.dot.gov"
  sourceTitle   String              // Title of the source article/document
  publishedAt   DateTime?           // When the source item was published (if known)
  // Extracted insight
  industry      String              // "trucking" | "law" | "restaurant" | "general"
  headline      String              // 1-line plain-English summary of the insight
  insight       String              @db.Text // 2-4 sentence explanation of why this matters to the client's clients
  contentAngle  String              @db.Text // Specific article angle/thesis derived from this insight
  keywords      String[]            @default([]) // Relevant search queries this insight maps to
  shareScore    Int                 @default(50) // 0-100 estimate of share-worthiness / novelty
  recencyScore  Int                 @default(50) // 0-100 how fresh the source is
  status        ResearchSignalStatus @default(fresh)
  consumedBy    String?             // AgentArtifact.id of the brief that consumed this
  site          Site                @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([siteId, status])
  @@index([siteId, industry])
  @@index([siteId, shareScore])
  @@map("research_signals")
}
